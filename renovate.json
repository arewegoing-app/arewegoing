{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:nonBusinessHours",
    ":timezone(America/Los_Angeles)"
  ],
  "labels": ["dependencies"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch and minor bumps for stable packages (not 0.x)",
      "matchUpdateTypes": ["patch", "minor"],
      "matchCurrentVersion": "!/^0\\./",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Major bumps always require manual review and dashboard approval",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group all dev-dependency patch/minor bumps into one PR and auto-merge",
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev-dependencies",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Pin GitHub Actions to commit SHAs and auto-merge digest/patch/minor updates",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true,
      "matchUpdateTypes": ["digest", "patch", "minor"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  }
}
