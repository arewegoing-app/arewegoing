{
  "name": "arewegoing",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "for f in __tests__/*.unit.ts; do echo \"=== $f ===\"; npx tsx \"$f\" || exit 1; done",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "reset": "rm -rf .gigs-data .gigs-data-* .gigs-outbox",
    "hooks:enable": "git config core.hooksPath .githooks",
    "hooks:disable": "git config --unset core.hooksPath"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@base-ui/react": "^1.5.0",
    "@electric-sql/pglite": "^0.4.5",
    "@neondatabase/serverless": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.31",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
