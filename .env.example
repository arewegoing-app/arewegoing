# Copy to .env.local for dev. Set in Vercel for previews + production.
# See README.md for the full table.

# --- Auth (required in prod) ---
# 32+ random chars. Generate: openssl rand -base64 32
AUTH_SECRET=
# 32+ random chars for signed action tokens. Server throws on first use if unset in prod.
GIGS_TOKEN_SECRET=

# --- Database (optional) ---
# Neon Postgres connection string. If unset, PGlite (in-memory in serverless) is used.
DATABASE_URL=

# --- Email (optional) ---
# If unset, emails write to .gigs-outbox/*.json for local testing.
RESEND_API_KEY=
RESEND_FROM=

# Bearer token for /api/inbound/email. Route returns 503 if unset.
# To disable auth locally for testing: set INBOUND_AUTH_OFF=1
INBOUND_SECRET=
# INBOUND_AUTH_OFF=1

# --- OAuth (optional, non-prod only) ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Stripe (optional) ---
# If unset, deposit holds use a stub.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- Logging (optional) ---
# debug | info | warn | error. Defaults: info (prod), debug (dev).
LOG_LEVEL=
